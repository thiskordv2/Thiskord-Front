<Page
    x:Class="Thiskord_Front.Pages.InscriptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <StackPanel Orientation="Vertical" Spacing="60"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="350"
                   >

            <TextBlock Text="Inscription"
                       FontFamily="Arial"
                       FontSize="24"
                       FontStyle="Italic"
                       TextWrapping="WrapWholeWords"
                       HorizontalAlignment="Center"/>

            <TextBox x:Name="MailTextBox"
                     Width="250"
                     Height="80"
                     Header="Mail"
                     PlaceholderText="Entrez votre email"
                     FontFamily="Arial"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"/>

            <TextBox x:Name="UserTextBox"
                     Width="250"
                     Height="80"
                     Header="Nom d'utilisateur"
                     PlaceholderText="Entrez votre nom d'utilisateur"
                     FontFamily="Arial"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"/>

            <PasswordBox x:Name="PasswordBox1"
                         Header="Mot de passe"
                         PlaceholderText="Entrez votre mot de passe"
                         Width="250"
                         Height="80"
                         PasswordRevealMode="Hidden"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"/>

            <PasswordBox x:Name="PasswordBox2"
                         Header="Vérification mot de passe"
                         PlaceholderText="Confirmez votre mot de passe"
                         Width="250"
                         Height="80"
                         PasswordRevealMode="Hidden"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"/>

            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="Red"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       FontFamily="Arial"
                       FontSize="14"
                       Margin="0,10,0,10"/>

            <Button Content="Inscription"
                    FontFamily="Arial"
                    FontSize="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="Button_Inscription_Click"/>
        </StackPanel>
    </Grid>
</Page>
