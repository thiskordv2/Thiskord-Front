<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Thiskord_Front.Views.ProjectSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Views"
    xmlns:models="using:Thiskord_Front.Models.Project"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel
            MaxWidth="600"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="24">

            <TextBlock
                Text="{x:Bind ViewModel.EditTitle, Mode=OneWay}"
                Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel Spacing="8">
                <TextBlock Text="Nom du projet" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox
                    Text="{x:Bind ViewModel.ProjectName, Mode=TwoWay}"
                    PlaceholderText="Entrez le nom du projet"
                    HorizontalAlignment="Stretch" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Description" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox
                    PlaceholderText="Entrez une description"
                    HorizontalAlignment="Stretch"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Text="{x:Bind ViewModel.ProjectDescription, Mode=TwoWay}"
                    Height="120" />
            </StackPanel>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="SaveButton"
                    Grid.Column="0"
                    Content="Sauvegarder"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}" 
                    Command="{x:Bind ViewModel.SaveProjectCommand}"
                    />

                <Button
                    x:Name="DeleteButton"
                    Grid.Column="1"
                    Content="Supprimer le projet"
                    Command="{x:Bind ViewModel.DeleteProjectCommand}"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"/>

                <Button
                    x:Name="CancelButton"
                    Grid.Column="2"
                    Content="Annuler"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CancelEditCommand}"/>
            </Grid>

        </StackPanel>
    </Grid>
</Page>
