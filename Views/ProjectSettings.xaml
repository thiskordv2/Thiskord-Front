<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Thiskord_Front.Views.ProjectSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Views"
    xmlns:models="using:Thiskord_Front.Models.Project"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8BFBF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#F7FCFE"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F7FCFE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="SidebarButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Background="#1E1E1E" Padding="48">

        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="260"/>
            <!-- Contenu -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR GAUCHE ══ -->
        <Border
            Grid.Column="0"
            Background="#1A1A1A"
            CornerRadius="12,0,0,12">

            <StackPanel Padding="0,32,0,32">

                <TextBlock
                    Text="PARAMÈTRES"
                    Foreground="#888888"
                    FontSize="12"
                    FontWeight="SemiBold"
                    CharacterSpacing="80"
                    Margin="20,0,0,14"/>

                <Button Style="{StaticResource SidebarButtonActiveStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="#F7FCFE"/>
                        <TextBlock Text="Général" Foreground="#F7FCFE" FontSize="15"/>
                    </StackPanel>
                </Button>

                <Rectangle Height="1" Fill="#333333" Margin="20,20"/>

                <TextBlock
                    Text="ZONE DE DANGER"
                    Foreground="#888888"
                    FontSize="12"
                    FontWeight="SemiBold"
                    CharacterSpacing="80"
                    Margin="20,0,0,14"/>

                <Button
                    Style="{StaticResource SidebarButtonStyle}"
                    Command="{x:Bind ViewModel.DeleteProjectCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE74D;" FontSize="18" Foreground="#E74C3C"/>
                        <TextBlock Text="Supprimer le projet" Foreground="#E74C3C" FontSize="15"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══ CONTENU PRINCIPAL ══ -->
        <Border
            Grid.Column="1"
            Background="#242424"
            CornerRadius="0,12,12,0">

            <Grid Padding="48,40,48,40">
                <Grid.RowDefinitions>
                    <!-- Titre -->
                    <RowDefinition Height="Auto"/>
                    <!-- Spacer -->
                    <RowDefinition Height="36"/>
                    <!-- Nom du projet -->
                    <RowDefinition Height="Auto"/>
                    <!-- Spacer -->
                    <RowDefinition Height="24"/>
                    <!-- Description -->
                    <RowDefinition Height="Auto"/>
                    <!-- Push boutons vers le bas -->
                    <RowDefinition Height="*"/>
                    <!-- Boutons -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Titre -->
                <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind ViewModel.EditTitle, Mode=OneWay}"
                    Foreground="#F7FCFE"
                    FontSize="26"
                    FontWeight="SemiBold"/>

                <!-- Nom du projet -->
                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBlock Text="Nom du projet" Style="{StaticResource LabelStyle}"/>
                    <TextBox
                        Style="{StaticResource DarkTextBoxStyle}"
                        Text="{x:Bind ViewModel.ProjectName, Mode=TwoWay}"
                        PlaceholderText="Nom du projet"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Grid.Row="4" Spacing="8">
                    <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                    <TextBox
                        Style="{StaticResource DarkTextBoxStyle}"
                        Text="{x:Bind ViewModel.ProjectDescription, Mode=TwoWay}"
                        PlaceholderText="Description du projet"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Height="180"/>
                </StackPanel>

                <!-- Boutons -->
                <StackPanel
                    Grid.Row="6"
                    Orientation="Horizontal"
                    Spacing="14"
                    HorizontalAlignment="Right">

                    <Button
                        Content="Annuler"
                        Command="{x:Bind ViewModel.CancelEditCommand}"
                        Background="#333333"
                        Foreground="#F7FCFE"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="24,10"
                        FontSize="14"/>

                    <Button
                        Content="Enregistrer les modifications"
                        Command="{x:Bind ViewModel.SaveProjectCommand}"
                        Background="#4CAF82"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        CornerRadius="20"
                        Padding="24,10"
                        FontSize="14"
                        FontWeight="SemiBold"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>
