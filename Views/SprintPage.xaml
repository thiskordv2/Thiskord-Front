<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Thiskord_Front.Views.SprintPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Views"
    xmlns:gestion="using:Thiskord_Front.Models.GestionProjet"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Détails du sprint" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Affichez ici le titre, les dates et les tâches du sprint sélectionné." TextWrapping="Wrap" Opacity="0.7" />
            <TextBlock Text="Titre" FontWeight="SemiBold" />
            <TextBlock Text="{x:Bind ViewModel.Sprint.sprint_goal, Mode=OneWay}" FontSize="18" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20">
            <StackPanel Width="250">
                <TextBlock Text="Début" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind ViewModel.Sprint.sprint_begin_date, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Width="250">
                <TextBlock Text="Fin" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind ViewModel.Sprint.sprint_end_date, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Ajouter une tâche" Click="AddTaskButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="4" Spacing="10">
            <TextBlock Text="Tâches du sprint" FontWeight="SemiBold" FontSize="16" />
            <!-- Table Headers -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Titre" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="Description" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="Statut" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="Créateur" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="Responsable" FontWeight="Bold" />
                <TextBlock Grid.Column="5" Text="Créé le" FontWeight="Bold" />
                <TextBlock Grid.Column="6" Text="Actions" FontWeight="Bold" />
            </Grid>

            <!-- Tasks Table -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ListView x:Name="TasksListView" ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,5" Background="#FF1B1B1B" Padding="10" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding task_title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1" Text="{Binding task_desc}" TextWrapping="Wrap" Opacity="0.8" />
                            <TextBlock Grid.Column="2" Text="{Binding task_status}" />
                            <TextBlock Grid.Column="3" Text="{Binding id_creator}" />
                            <TextBlock Grid.Column="4" Text="{Binding id_resp}" />
                            <TextBlock Grid.Column="5" Text="{Binding created_at}" />
                            <Button Grid.Column="6" Content="Supprimer" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                    Command="{Binding ElementName=TasksListView, Path=DataContext.DeleteTaskCommand}" CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
