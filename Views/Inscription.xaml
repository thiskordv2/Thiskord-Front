<Page
    x:Class="Thiskord_Front.Views.InscriptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Orientation="Vertical" Spacing="10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Width="350"
                   >

            <TextBlock Text="Inscription"
                       FontFamily="Arial"
                       FontSize="24"
                       FontStyle="Italic"
                       TextWrapping="WrapWholeWords"
                       CharacterSpacing="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0 0 0 40"/>

            <TextBox x:Name="UserTextBox"
                     Width="260"
                     Height="58"
                     Header="Nom d'utilisateur"
                     PlaceholderText="Entrez votre nom d'utilisateur"
                     FontFamily="Arial"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"/>

            <TextBox x:Name="MailTextBox"
                     Width="260"
                     Height="58"
                     Header="Mail"
                     PlaceholderText="Entrez votre email"
                     FontFamily="Arial"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
            
            <PasswordBox x:Name="PasswordBox1"
                         Header="Mot de passe"
                         PlaceholderText="Entrez votre mot de passe"
                         Width="260"
                         Height="60"
                         PasswordRevealMode="Hidden"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"/>

            <PasswordBox x:Name="PasswordBox2"
                         Header="Vérification mot de passe"
                         PlaceholderText="Confirmez votre mot de passe"
                         Width="260"
                         Height="60"
                         PasswordRevealMode="Hidden"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"/>

            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="Red"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       FontFamily="Arial"
                       FontSize="14"
                       Margin="0,10,0,10"/>

            <Button Content="Inscription"
                    FontFamily="Arial"
                    FontSize="18"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="180"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="Button_Inscription_Click"
                    Margin="0 10 0 0"/>
            
            <Button Content="Connexion"
                    FontFamily="Arial"
                    Style="{StaticResource SubtleButtonStyle}"
                    FontSize="16"
                    Width="160"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="Button_Connexion_Click"/>
        </StackPanel>
    </Grid>
</Page>
