<Page
    x:Class="Thiskord_Front.Views.Navigateur"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Thiskord_Front.Views"
    xmlns:models="using:Thiskord_Front.Models.Project"
    xmlns:gestion="using:Thiskord_Front.Models.GestionProjet"
    xmlns:models2="using:Thiskord_Front.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" 
          Width="150" 
          HorizontalAlignment="Left" 
          VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Spacing="5">
                <DropDownButton Grid.Row="0" Content="Mes serveurs"  HorizontalAlignment="Center" Margin="0,15,0,0">
                <DropDownButton.Flyout>
                    <MenuFlyout x:Name="ServerMenuFlyout" 
                                Placement="Bottom"
                                Opening="ServerMenuFlyout_Opening">
                        <MenuFlyoutItem Text="Chargement"/>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            </StackPanel>
            
            <ListView
            Grid.Row="1"
            x:Name="channelListing"
            ItemsSource="{x:Bind ViewModel.Channels, Mode=OneWay}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Margin="0,10,0,10"
            SelectionMode="Single"
            SelectionChanged="ChannelListing_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Channel">
                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}" FontSize="12" HorizontalAlignment="Left" Foreground="#FFFFFFFF" Padding="10,5,0,5">
                            <TextBlock.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Tag="edit" Text="Modifier" Icon="Edit" 
                                                    Command="{x:Bind local:Navigateur.EditChannelFromXamlCommand}"
                                                    CommandParameter="{x:Bind}"/>
                                    <MenuFlyoutItem Tag="delete" Text="Supprimer" Icon="Delete" 
                                                    Command="{x:Bind local:Navigateur.DeleteChannelFromXamlCommand}"
                                                    CommandParameter="{x:Bind}"/>
                                </MenuFlyout>
                            </TextBlock.ContextFlyout>
                        </TextBlock>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView
            Grid.Row="2"
            x:Name="sprintListing"
            ItemsSource="{x:Bind ViewModel.Sprints, Mode=OneWay}"
            SelectionMode="Single"
            SelectionChanged="SprintListing_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="gestion:Sprint">
                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="3" Orientation="Vertical" Padding="0,0,0,10">
                <PersonPicture 
                ProfilePicture="https://learn.microsoft.com/windows/uwp/contacts-and-calendar/images/shoulder-tap-static-payload.png" 
                Width="50" Height="50"
                HorizontalAlignment="Center"/>
                <StackPanel.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Créer un projet" Command="{x:Bind ViewModel.CreateProjectBtnCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE710;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Rejoindre un projet" Command="{x:Bind ViewModel.JoinProjectCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8FD;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Tag="disconnect" Text="Se déconnecter" Command="{x:Bind ViewModel.LogoutCommand}" >
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xF3B1;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </StackPanel.ContextFlyout>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Column="1" 
                   Grid.Row="0"
                   Text="{x:Bind ViewModel.SelectedProject.name, Mode=OneWay}"
                   FontSize="24"
                   Margin="10,10,0,10"/>
        
        <Frame x:Name="InnerFrame" 
           Grid.Column="1"
           Grid.Row="1"
           Grid.RowSpan="2">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition  />
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>

        <Grid Grid.Column="2" VerticalAlignment="Stretch" x:Name="RightPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0"
                       Text="Membres"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       Margin="12,12,12,8"/>

            <ListView
                Grid.Row="1"
                x:Name="UsersListView"
                SelectionMode="Single"
                ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models2:UserAccount">
                        <Grid Padding="0,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <PersonPicture
                                Grid.Column="0"
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                ProfilePicture="https://learn.microsoft.com/windows/uwp/contacts-and-calendar/images/shoulder-tap-static-payload.png"
                                Width="30" Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind user_name}"
                                x:Phase="1"
                                Style="{ThemeResource BaseTextBlockStyle}"
                                Margin="12,6,0,0"/>
                            <TextBlock
                                Grid.Column="1"
                                Grid.Row="1"
                                Text="{x:Bind user_mail}"
                                x:Phase="2"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                Margin="12,0,0,6"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Button 
                x:Name="ButtonEditProject"
                Grid.Row="2" 
                HorizontalAlignment="Right" 
                Margin="0, 0, 10, 10">
                <FontIcon Glyph="&#xE713;" />
                <Button.Flyout>
                    <MenuFlyout Placement="Top">
                        <MenuFlyoutItem 
                            Text="Modifier le projet"
                            Command="{x:Bind ViewModel.ProjectSettingsCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70F;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>

                        <MenuFlyoutItem 
                            Text="Inviter des personnes"
                            Command="{x:Bind ViewModel.InviteCommand}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8FA;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>
        
    </Grid>
</Page>